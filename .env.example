# ============================================================================
# TaxMind Books — environment template
# Copy to .env and fill in real values for local development.
# Do NOT commit the populated .env file.
# ============================================================================

# ---- Database ----
DATABASE_URL=postgresql+psycopg://taxmind:taxmind@localhost:5432/taxmind_books

# ---- Redis (Celery broker + rate limits) ----
REDIS_URL=redis://localhost:6379/0

# ---- Auth / crypto ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-long-random-string
SECRET_KEY=change-me-to-another-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---- LLM providers ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Object storage (S3 / R2 / compatible) ----
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- Tally Connector ----
TALLY_HOST=localhost
TALLY_PORT=9000
CONNECTOR_PORT=8001
CONNECTOR_JWT_SECRET=change-me-to-a-different-long-random-string

# ---- Frontend origins (CORS pin list) ----
WEB_URL=http://localhost:5173
MOBILE_URL=http://localhost:19006

# ---- App / runtime ----
APP_ENV=development
LOG_LEVEL=INFO

# ---- Worker / dispatch model (P0.58, BUG-Books-003) ----
# Phase 0 is intentionally single-process: the connector_registry is
# held in the API uvicorn's memory (see
# backend/app/services/tally/connector_registry.py docstring line 12),
# so the voucher dispatcher MUST run in the same process as the WS
# handler. Setting CELERY_TASK_ALWAYS_EAGER=1 routes
# enqueue_voucher_post through an in-process asyncio.create_task
# instead of Celery .delay() — the API 201 returns immediately and the
# dispatch fires on the same event loop the WS lives on.
#
# Leaving this unset (or "0") restores the Celery worker path, which
# is intended for Phase 0.5+ once connector_registry becomes Redis
# pub/sub-backed. Until then, a separate worker process WILL strand
# every voucher (the worker's registry is empty by construction).
CELERY_TASK_ALWAYS_EAGER=1
